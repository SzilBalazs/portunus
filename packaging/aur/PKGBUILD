# >>> TEMPLATE NOTE (stripped on render by release.yml) >>>
# TEMPLATE - not buildable as-is. The release workflow (.github/workflows/
# release.yml) renders this on each tag push, replacing the @PKGVER@ and
# @SHA256@ placeholders below with the tag version and the sha256 of the built
# .deb, and attaches the rendered PKGBUILD to the GitHub release.
# <<< TEMPLATE NOTE <<<
# Binary package: installs the prebuilt .deb attached to the GitHub release.
# The .deb is self-contained - it bundles libpdfium, the poppler tools, and the
# English tesseract data under /usr/lib/portunus, so PDF preview, content search,
# and OCR work with nothing extra installed. It links the host's own
# WebKitGTK/GTK (depends below), so no stale bundled WebKit.

pkgname=portunus-bin
_pkgname=portunus
pkgver=@PKGVER@
pkgrel=1
pkgdesc="Application launcher and power-user search for Wayland"
arch=('x86_64')
url="https://github.com/SzilBalazs/portunus"
license=('Apache-2.0')
provides=("portunus=$pkgver")
conflicts=('portunus')
options=('!debug')   # strip vendored ELFs; no separate -debug split for prebuilts
depends=(
  'webkit2gtk-4.1'
  'gtk3'
  'gtk-layer-shell'   # binary links it; needed even though layer_shell is opt-in
  'libarchive'        # bundled libtesseract.so.5 links libarchive.so.13 (not bundled)
  'nss'               # bundled libpoppler.so.134 links libnss3/libsmime3 (PDF sig verify)
  'nspr'              # transitive of nss (libnspr4/libplc4/libplds4)
  'libssh'            # bundled libcurl-gnutls.so.4 links libssh.so.4 (sftp backend)
  'rtmpdump'          # bundled libcurl-gnutls.so.4 links librtmp.so.1 (rtmp backend)
)
optdepends=(
  'dictd: dictionary lookups (dict provider)'
  'cliphist: clipboard history provider'
  'wl-clipboard: clipboard history provider (paste)'
)
source=("$_pkgname-$pkgver.deb::$url/releases/download/v$pkgver/${_pkgname}_${pkgver}_amd64.deb")
sha256sums=('@SHA256@')

package() {
  ar x "$srcdir/$_pkgname-$pkgver.deb"
  bsdtar -xf data.tar.* -C "$pkgdir/"
}
