# Binary package: installs the prebuilt .deb attached to the GitHub release.
# The .deb is self-contained - it bundles libpdfium, the poppler tools, and the
# English tesseract data under /usr/lib/portunus, so PDF preview, content search,
# and OCR work with nothing extra installed. It links the host's own
# WebKitGTK/GTK (depends below), so no stale bundled WebKit.

pkgname=portunus-bin
_pkgname=portunus
pkgver=0.1.2
pkgrel=1
pkgdesc="Application launcher and power-user search for Wayland"
arch=('x86_64')
url="https://github.com/SzilBalazs/portunus"
license=('Apache-2.0')
provides=('portunus')
conflicts=('portunus')
options=('!strip' '!debug')   # prebuilt binaries; nothing to strip, skip -debug split
depends=(
  'webkit2gtk-4.1'
  'gtk3'
  'gtk-layer-shell'   # binary links it; needed even though layer_shell is opt-in
)
optdepends=(
  'dictd: dictionary lookups (dict provider)'
  'cliphist: clipboard history provider'
  'wl-clipboard: clipboard history provider (paste)'
)
source=("$_pkgname-$pkgver.deb::$url/releases/download/v$pkgver/${_pkgname}_${pkgver}_amd64.deb")
sha256sums=('3e4a7250fd3df9a67f707765f6c4ab7a058dc39885f8fc61c7b5cb083840d922')

package() {
  ar x "$srcdir/$_pkgname-$pkgver.deb" data.tar.gz
  tar -xf data.tar.gz -C "$pkgdir/"
}
