api = 4
name = "{{name}}"
version = "0.1.0"
description = "Describe what {{name}} does"
author = ""

# One searchable command. It shows up as a "Search {{name}}" entry in the
# launcher root, found by fuzzy-matching its title and `keywords`; Enter opens
# it as a scope and every keystroke then routes to your `search`. An empty
# scope query is the browse state - return your default/browse results. Add
# more [[commands]] blocks for extensions that do several distinct things
# (dispatch on the wire's `command` field in lib.rs) - see
# examples/extensions/gh/manifest.toml.
[[commands]]
name = "{{name}}"               # [a-z0-9_-]+, unique within the extension
title = "Search {{name}}"       # required; the searchable launcher entry
mode = "scope"                  # scope | action
keywords = ["{{name}}"]         # optional search synonyms folded into the fuzzy match
# min_query_len = 1             # optional: gate `search` until the query is this long
# always = false                # run live in root search on every keystroke (discouraged - slower)
# chip = "{{name}}"             # optional: active-mode chip label; defaults to title
# placeholder = "Search…"       # optional: input placeholder while the mode is active

[limits]
search_timeout_ms = 100
# Budget for the optional async `query` export (network work, off the
# keystroke path). Uncomment when you export `query`.
# query_timeout_ms = 10000
# preview_timeout_ms = 500

# Permissions are all opt-in and shown to the user before enabling:
# [permissions]
# network = ["api.example.com"]   # exact hosts for extism HTTP (or a lone "*" = any host, sandbox-relaxing)
# kv = true                       # persistent key-value store (10 MB)
# clipboard = true                # clipboard_write host fn (activate effects
#                                 # can copy text WITHOUT this permission)
# open_url = true                 # open_url host fn (effects can open urls
#                                 # WITHOUT this permission)
# paste = true                    # Paste activate effect (synthetic Ctrl+V)
#
# ⚠ DANGER - `spawn` runs real OS programs and BREAKS THE SANDBOX. A spawned
# process runs with the user's full account access; extensions are normally
# confined to wasm and cannot touch the system. Only uncomment if it is
# essential to what your extension does - the user is shown a hard warning and
# must explicitly confirm before an extension requesting it can be enabled.
# The list is an allowlist of exact command names/paths; the SpawnProcess
# activate effect may only launch a command that appears here (argv only, never
# a shell). NOTE: allowlisting a shell/interpreter (sh, bash, python, env, …)
# re-grants arbitrary execution because the args are unrestricted.
# spawn = ["notify-send"]

# Schedule a background `refresh` export (cache warming, off keystroke path):
# [background]
# refresh_interval_secs = 3600

# User-editable settings, rendered in Portunus Settings, read via setting_str():
# [[settings]]
# key = "greeting"
# type = "string"
# label = "Greeting text"
# default = "hello"

# A secret (API key/token): masked input, stored in the system keyring,
# never in config.toml. Read it with setting_str() like any other setting.
# [[settings]]
# key = "api_key"
# type = "secret"
# label = "API key"
