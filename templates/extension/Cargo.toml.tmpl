[package]
name = "{{name}}"
version = "0.1.0"
edition = "2021"

[lib]
crate-type = ["cdylib"]

[dependencies]
# Pinned to the Portunus release this scaffold came from. If you are hacking
# inside the Portunus repo, switch to: { path = "../../extension-sdk" }
portunus-ext-sdk = { git = "https://github.com/SzilBalazs/portunus", tag = "{{sdk_tag}}" }
serde_json = "1"

[profile.release]
opt-level = "s"
lto = true
