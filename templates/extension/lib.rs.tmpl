//! {{name}} - a Portunus extension.
//!
//! Iterate with:
//!   cargo build --release --target wasm32-unknown-unknown
//!   portunus ext dev .        # symlink + auto-reload on rebuild
//!
//! The host calls `search` on each (command-gated) keystroke, `activate` when
//! the user picks a result/action, and optionally `preview`/`refresh`. Every
//! call carries `command`, naming which `[[commands]]` manifest entry is
//! running - this scaffold declares one, so it's ignored below.

// The pdk macros expand to `extism_pdk::…` paths - this alias satisfies them
// without adding extism-pdk as a direct dependency.
use portunus_ext_sdk::guest::extism_pdk;
use portunus_ext_sdk::guest::{plugin_fn, FnResult, Json};
use portunus_ext_sdk::{
    Action, ActivateEffect, ActivateInput, ActivateOutput, ExtensionResult, MetadataItem,
    PreviewContent, PreviewInput, SearchInput, SearchOutput, ToastLevel,
};

#[plugin_fn]
pub fn search(input: Json<SearchInput>) -> FnResult<Json<SearchOutput>> {
    // input.0.command names the [[commands]] entry being invoked - match on
    // it here once you add more than one command to the manifest, e.g.:
    //   match input.0.command.as_str() {
    //       "{{name}}" => search_{{crate_name}}(&input.0),
    //       "other" => search_other(&input.0),
    //       _ => Ok(Json(SearchOutput::default())),
    //   }

    // `query` is the whole term the user typed in the scope. An empty query
    // means they just entered the mode (via its launcher entry) - return
    // browse results (or nothing).
    let query = input.0.query.trim().to_lowercase();

    let results = vec![ExtensionResult {
        id: "hello".into(),
        title: if query.is_empty() {
            "Hello from {{name}}".into()
        } else {
            format!("{{name}}: {query}")
        },
        subtitle: Some("Enter copies this text".into()),
        relevance: 80.0,
        actions: vec![Action { id: "copy".into(), label: "Copy text".into(), hint: None, opens_form: false }],
        ..Default::default()
    }];
    Ok(Json(SearchOutput { results }))
}

#[plugin_fn]
pub fn activate(input: Json<ActivateInput>) -> FnResult<Json<ActivateOutput>> {
    // input.0.command is set here too (an Action command's direct invocation
    // gets its name with a synthetic default result).
    let result = input.0.result;
    // Effects run host-side after this returns; copying text and opening
    // http(s) urls need no permissions on the explicit activation path.
    // Beyond copy/open/toast there are `show_form` (modal input form whose
    // submit calls `activate` again with `form_values`), `keep_open`,
    // `refresh_results`, and `paste` - see EXTENSIONS.md "Forms". E.g.:
    //   return Ok(Json(ActivateOutput::form(
    //       "Add note",
    //       vec![FormField::new("text", "Note", "textarea").required()],
    //       "save-note",
    //   )));
    Ok(Json(ActivateOutput {
        effects: vec![
            ActivateEffect::CopyText { text: result.title.clone() },
            ActivateEffect::ShowToast { message: "Copied!".into(), level: ToastLevel::Success },
        ],
    }))
}

#[plugin_fn]
pub fn preview(input: Json<PreviewInput>) -> FnResult<Json<PreviewContent>> {
    let result = input.0.result;
    Ok(Json(PreviewContent::Metadata {
        items: vec![
            MetadataItem { label: "Id".into(), value: result.id },
            MetadataItem { label: "Title".into(), value: result.title },
        ],
    }))
}

